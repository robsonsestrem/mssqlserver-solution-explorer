                                                <ScalarOperator ScalarString="CASE WHEN SYSREQUESTS.[deadlock_priority]&lt;=(-5) THEN 'Low' ELSE CASE WHEN SYSREQUESTS.[deadlock_priority]&gt;(-5) AND SYSREQUESTS.[deadlock_priority]&lt;(5) THEN 'Normal' ELSE CASE WHEN SYSREQUESTS.[deadlock_priority]&gt;=(5) THEN 'High' ELSE NULL END END END+' ('+CONVERT(varchar(3),SYSREQUESTS.[deadlock_priority],0)+')'">
                                                  <Arithmetic Operation="ADD">
                                                    <ScalarOperator>
                                                      <Arithmetic Operation="ADD">
                                                        <ScalarOperator>
                                                          <Arithmetic Operation="ADD">
                                                            <ScalarOperator>
                                                              <IF>
                                                                <Condition>
                                                                  <ScalarOperator>
                                                                    <Compare CompareOp="LE">
                                                                      <ScalarOperator>
                                                                        <Identifier>
                                                                          <ColumnReference Table="[SYSREQUESTS]" Column="deadlock_priority" />
                                                                        </Identifier>
                                                                      </ScalarOperator>
                                                                      <ScalarOperator>
                                                                        <Const ConstValue="(-5)" />
                                                                      </ScalarOperator>
                                                                    </Compare>
                                                                  </ScalarOperator>
                                                                </Condition>
                                                                <Then>
                                                                  <ScalarOperator>
                                                                    <Const ConstValue="'Low'" />
                                                                  </ScalarOperator>
                                                                </Then>
                                                                <Else>
                                                                  <ScalarOperator>
                                                                    <IF>
                                                                      <Condition>
                                                                        <ScalarOperator>
                                                                          <Logical Operation="AND">
                                                                            <ScalarOperator>
                                                                              <Compare CompareOp="GT">
                                                                                <ScalarOperator>
                                                                                  <Identifier>
                                                                                    <ColumnReference Table="[SYSREQUESTS]" Column="deadlock_priority" />
                                                                                  </Identifier>
                                                                                </ScalarOperator>
                                                                                <ScalarOperator>
                                                                                  <Const ConstValue="(-5)" />
                                                                                </ScalarOperator>
                                                                              </Compare>
                                                                            </ScalarOperator>
                                                                            <ScalarOperator>
                                                                              <Compare CompareOp="LT">
                                                                                <ScalarOperator>
                                                                                  <Identifier>
                                                                                    <ColumnReference Table="[SYSREQUESTS]" Column="deadlock_priority" />
                                                                                  </Identifier>
                                                                                </ScalarOperator>
                                                                                <ScalarOperator>
                                                                                  <Const ConstValue="(5)" />
                                                                                </ScalarOperator>
                                                                              </Compare>
                                                                            </ScalarOperator>
                                                                          </Logical>
                                                                        </ScalarOperator>
                                                                      </Condition>
                                                                      <Then>
                                                                        <ScalarOperator>
                                                                          <Const ConstValue="'Normal'" />
                                                                        </ScalarOperator>
                                                                      </Then>
                                                                      <Else>
                                                                        <ScalarOperator>
                                                                          <IF>
                                                                            <Condition>
                                                                              <ScalarOperator>
                                                                                <Compare CompareOp="GE">
                                                                                  <ScalarOperator>
                                                                                    <Identifier>
                                                                                      <ColumnReference Table="[SYSREQUESTS]" Column="deadlock_priority" />
                                                                                    </Identifier>
                                                                                  </ScalarOperator>
                                                                                  <ScalarOperator>
                                                                                    <Const ConstValue="(5)" />
                                                                                  </ScalarOperator>
                                                                                </Compare>
                                                                              </ScalarOperator>
                                                                            </Condition>
                                                                            <Then>
                                                                              <ScalarOperator>
                                                                                <Const ConstValue="'High'" />
                                                                              </ScalarOperator>
                                                                            </Then>
                                                                            <Else>
                                                                              <ScalarOperator>
                                                                                <Const ConstValue="NULL" />
                                                                              </ScalarOperator>
                                                                            </Else>
                                                                          </IF>
                                                                        </ScalarOperator>
                                                                      </Else>
                                                                    </IF>
                                                                  </ScalarOperator>
                                                                </Else>
                                                              </IF>
                                                            </ScalarOperator>
                                                            <ScalarOperator>
